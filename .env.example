# --- Server ---
PORT=3000
NODE_ENV=production

# --- Data ---
# Directory the legacy JSON database, its .bak snapshot, and any .corrupt-* files live in.
CUPID_DATA_DIR=./data

# --- Database (Prisma / Postgres) ---
# Local: point both at your local Postgres.
# Supabase: DATABASE_URL = pooled (Supavisor) URL, port 6543, add ?pgbouncer=true&sslmode=require
#           DIRECT_URL   = direct URL, port 5432, add ?sslmode=require  (used by migrations)
DATABASE_URL="postgresql://user:password@localhost:5432/cupid?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/cupid?schema=public"

# --- Ebook storage (Supabase Storage) ---
# Private bucket for giftable ebook files. Downloads are disabled if unset.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
EBOOK_BUCKET="ebooks"
CUPID_DOWNLOAD_MAX=5
CUPID_DOWNLOAD_TTL_MS=2592000000

# --- Admin (CHANGE THIS) ---
CUPID_ADMIN_PASS=change-me
CUPID_ADMIN_TTL_MS=7200000

# --- Rate limiting ---
CUPID_AUTH_WINDOW_MS=900000
CUPID_AUTH_MAX=50
CUPID_API_MAX=600

# --- Email ---
# Leave SMTP_URL unset to record mail to the in-app outbox (visible at
# /api/admin/outbox) instead of sending. Set it to go live.
# SMTP_URL=smtp://user:pass@smtp.example.com:587
MAIL_FROM=Cupid <hello@cupid.local>
CONTACT_TO=team@cupid.local
APP_URL=http://localhost:3000

# --- Security ---
# Proxy hops in front of the app (rate-limit client IP). Default 1.
TRUST_PROXY=1
# Canonical host for the production HTTPS redirect (avoids trusting the Host header).
# CANONICAL_HOST=cupid.example.com
SECURITY_CONTACT=mailto:security@cupid.local
